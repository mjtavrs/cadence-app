{
  "name": "cadence-saas",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "infra"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "start": "npm --workspace apps/web run start",
    "lint": "npm --workspace apps/web run lint",
    "web:dev": "npm --workspace apps/web run dev",
    "web:build": "npm --workspace apps/web run build",
    "web:start": "npm --workspace apps/web run start",
    "web:lint": "npm --workspace apps/web run lint",
    "infra:cdk": "npm --workspace infra run cdk --"
  }
}
